# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Public Site Settings
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_ADMIN_EMAIL=mohammadbitullah@gmail.com

# JWT Secret for additional security
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Admin Email (for initial setup)
ADMIN_EMAIL=mohammadbitullah@gmail.com

# ── SEO Verification Tokens ───────────────────────────────────────────────────
# Google Search Console: Settings → Ownership verification → HTML tag → content="..."
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_verification_token_here

# Bing Webmaster Tools: Settings → Ownership verification → HTML meta tag → content="..."
NEXT_PUBLIC_BING_SITE_VERIFICATION=your_bing_verification_token_here
